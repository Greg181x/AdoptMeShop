.btn-auth-primary{width:100%;padding:0.65rem;background:var(--blue);border:none;border-radius:8px;color:#fff;font-family:'Outfit',sans-serif;font-size:0.9rem;font-weight:700;cursor:pointer;margin-bottom:0.75rem;transition:all .15s}
