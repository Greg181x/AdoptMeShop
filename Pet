.auth-input{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.6rem 0.85rem;color:var(--text);font-family:'Outfit',sans-serif;font-size:0.83rem;outline:none;margin-bottom:0.6rem;transition:border-color .15s}
