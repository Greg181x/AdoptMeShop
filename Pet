<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<meta name="referrer" content="no-referrer">
<title>BloxBolt — Gaming Marketplace</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  /* ═════ CUSTOM GLOW EFFECT FOR ITEM CARDS (MODIFICAT) ═════ */
.item-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 30%; /* Am mărit aria de acoperire */
  /* Gradient mai saturat (0.4 în loc de 0.25) */
  background: linear-gradient(to bottom, rgba(59,158,255,0.45), transparent 90%);
  border-top-left-radius: 10px;
  border-top-right-radius: 10px;
  pointer-events: none;
  opacity: 1; /* Opacitate maximă */
  filter: blur(12px); /* Blur mai pronunțat pentru răspândire */
  z-index: 1;
}

.item-card .card-img-wrap::before {
  content: "";
  position: absolute;
  inset: 0;
  /* Strălucire centrală mai intensă */
  background: radial-gradient(circle at 30% 10%, rgba(59,158,255,0.35), transparent 75%);
  pointer-events: none;
  z-index: 1;
}

/* Am adăugat și un efect de hover mai puternic pentru margini */
.item-card:hover {
  border-color: var(--blue) !important;
  box-shadow: 0 0 20px rgba(59,158,255,0.25);
}

:root {
  --bg:#0c0e14; --bg2:#10131a; --bg3:#13161f;
  --surface:#161b26; --surface2:#1c2133; --surface3:#202638;
  --border:rgba(255,255,255,0.07); --border2:rgba(255,255,255,0.12);
  --blue:#3b9eff; --blue2:#2b8aee; 
  /* Am mărit intensitatea variabilei de glow general */
  --blue-glow:rgba(59,158,255,0.5); 
  --text:#e8eaf2; --text2:#8b90a8; --muted:#4a4f64;
  --red:#ff4d6d; --green:#3dd68c; --orange:#ff9944; --yellow:#ffd166;
  --c-common:#8b90a8; --c-uncommon:#5d8af0; --c-rare:#3dd68c;
  --c-ultra:#b06aff; --c-legendary:#ffd166; --c-neon:#ff7a3d;
}
:root {
  --bg:#0c0e14; --bg2:#10131a; --bg3:#13161f;
  --surface:#161b26; --surface2:#1c2133; --surface3:#202638;
  --border:rgba(255,255,255,0.07); --border2:rgba(255,255,255,0.12);
  --blue:#3b9eff; --blue2:#2b8aee; --blue-glow:rgba(59,158,255,0.25);
  --text:#e8eaf2; --text2:#8b90a8; --muted:#4a4f64;
  --red:#ff4d6d; --green:#3dd68c; --orange:#ff9944; --yellow:#ffd166;
  --c-common:#8b90a8; --c-uncommon:#5d8af0; --c-rare:#3dd68c;
  --c-ultra:#b06aff; --c-legendary:#ffd166; --c-neon:#ff7a3d;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Outfit',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--muted);border-radius:3px}

/* ── PAGES ── */
.page{display:none;min-height:100vh;flex-direction:column}
.page.active{display:flex}

/* ── HEADER ── */
header{background:var(--bg2);border-bottom:1px solid var(--border);height:54px;display:flex;align-items:center;padding:0 1.5rem;gap:1rem;position:sticky;top:0;z-index:200}
.logo{font-size:1.1rem;font-weight:800;color:var(--text);text-decoration:none;display:flex;align-items:center;gap:0.5rem;margin-right:0.5rem;cursor:pointer}
.logo-box{width:28px;height:28px;background:var(--blue);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:0.75rem;box-shadow:0 0 12px var(--blue-glow)}
nav{display:flex;gap:0.1rem;flex:1}
nav a{display:flex;align-items:center;gap:0.3rem;padding:0.32rem 0.75rem;border-radius:6px;color:var(--text2);text-decoration:none;font-size:0.82rem;font-weight:500;transition:all .15s;cursor:pointer}
nav a:hover,nav a.active{color:var(--text);background:var(--surface2)}
nav a .dot{width:6px;height:6px;border-radius:50%;background:var(--blue);flex-shrink:0}
.header-actions{display:flex;align-items:center;gap:0.5rem;margin-left:auto}
.btn-login{padding:0.35rem 0.85rem;background:transparent;border:none;color:var(--text2);font-family:'Outfit',sans-serif;font-size:0.82rem;font-weight:600;cursor:pointer;border-radius:6px;transition:all .15s}
.btn-login:hover{color:var(--text);background:var(--surface)}
.btn-signup{padding:0.35rem 0.9rem;background:var(--blue);border:none;color:#fff;font-family:'Outfit',sans-serif;font-size:0.82rem;font-weight:700;cursor:pointer;border-radius:6px;transition:all .15s}
.btn-signup:hover{background:var(--blue2);box-shadow:0 0 14px var(--blue-glow)}
.header-user{display:flex;align-items:center;gap:0.6rem;cursor:pointer}
.avatar-sm{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--blue),#8b5cf6);display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700}

/* ══════════════════════════════
   POST-LOGIN BALANCE BAR
══════════════════════════════ */
.balance-bar{display:flex;align-items:center;gap:0.4rem;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:0.22rem 0.4rem 0.22rem 0.6rem;height:34px}
.balance-bar .bal-icon{color:var(--blue);font-size:0.9rem;font-weight:800;display:flex;align-items:center}
.balance-bar .bal-amount{font-size:0.88rem;font-weight:800;color:var(--text);white-space:nowrap}
.balance-bar .bal-amount .bal-cents{font-size:0.72rem;color:var(--text2);font-weight:600}
.balance-bar .bal-add{width:24px;height:24px;background:var(--blue);border:none;border-radius:5px;color:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:1rem;font-weight:700;transition:all .15s;margin-left:0.25rem}
.balance-bar .bal-add:hover{background:var(--blue2);box-shadow:0 0 8px var(--blue-glow)}
.cart-icon-btn{width:32px;height:32px;background:var(--surface);border:1px solid var(--border);border-radius:7px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text2);position:relative;transition:all .15s}
.cart-icon-btn:hover{border-color:var(--border2);color:var(--text)}
.cart-icon-btn .cart-dot{position:absolute;top:-3px;right:-3px;width:8px;height:8px;background:var(--blue);border-radius:50%;border:2px solid var(--bg2)}
.user-avatar-btn{width:32px;height:32px;border-radius:50%;overflow:hidden;cursor:pointer;border:2px solid var(--border2);transition:border-color .15s;flex-shrink:0}
.user-avatar-btn:hover{border-color:var(--blue)}
.user-avatar-btn img{width:100%;height:100%;object-fit:cover}
.user-avatar-btn .avatar-fallback{width:100%;height:100%;background:linear-gradient(135deg,#ff6b35,#f7931a);display:flex;align-items:center;justify-content:center;font-size:0.85rem}
.chevron-btn{width:22px;height:22px;display:flex;align-items:center;justify-content:center;color:var(--text2);cursor:pointer;transition:color .15s}
.chevron-btn:hover{color:var(--text)}

/* ── LAYOUT ── */
.layout{display:flex;flex:1}
.sidebar{width:210px;flex-shrink:0;background:var(--bg2);border-right:1px solid var(--border);padding:1.25rem 1rem;overflow-y:auto}
.main-content{flex:1;overflow-x:hidden}

/* ── SIDEBAR ── */
.filter-section{margin-bottom:1.4rem}
.filter-title{font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text2);margin-bottom:0.7rem;display:flex;align-items:center;justify-content:space-between}
.filter-title span{cursor:pointer;font-size:0.9rem;color:var(--muted)}

/* ══════════════════════════════
   DUAL RANGE SLIDER
══════════════════════════════ */
.price-row{display:flex;gap:0.4rem;margin-bottom:0.7rem}
.price-input-box{flex:1;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:0.35rem 0.55rem;display:flex;align-items:center;gap:0.3rem}
.price-input-box .pi-dollar{color:var(--blue);font-size:0.82rem;font-weight:700}
.price-input-box input{flex:1;background:transparent;border:none;outline:none;color:var(--text);font-family:'Outfit',sans-serif;font-size:0.82rem;font-weight:600;width:0;min-width:0}
.price-input-box input::placeholder{color:var(--muted)}

/* Dual range track */
.dual-range-wrap{position:relative;height:28px;display:flex;align-items:center;margin:0.2rem 0 0.3rem}
.dual-range-track{position:absolute;left:0;right:0;height:4px;background:var(--surface3);border-radius:2px}
.dual-range-fill{position:absolute;height:4px;background:var(--blue);border-radius:2px}
.dual-range-wrap input[type=range]{position:absolute;width:100%;height:4px;background:transparent;-webkit-appearance:none;appearance:none;pointer-events:none;outline:none}
.dual-range-wrap input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:18px;height:18px;border-radius:50%;background:#fff;border:2.5px solid var(--blue);cursor:pointer;pointer-events:all;box-shadow:0 2px 8px rgba(59,158,255,0.35);transition:box-shadow .15s,transform .15s}
.dual-range-wrap input[type=range]::-moz-range-thumb{width:18px;height:18px;border-radius:50%;background:#fff;border:2.5px solid var(--blue);cursor:pointer;pointer-events:all;box-shadow:0 2px 8px rgba(59,158,255,0.35)}
.dual-range-wrap input[type=range]::-webkit-slider-thumb:hover{box-shadow:0 2px 14px rgba(59,158,255,0.55);transform:scale(1.1)}

.check-item{display:flex;align-items:center;gap:0.5rem;padding:0.25rem 0;cursor:pointer;font-size:0.8rem;color:var(--text2);border-radius:5px;transition:color .15s}
.check-item:hover{color:var(--text)}
.check-box{width:14px;height:14px;border-radius:3px;border:1.5px solid var(--border2);background:transparent;flex-shrink:0;transition:all .15s;display:flex;align-items:center;justify-content:center;font-size:0.6rem}
.check-box.checked{background:var(--blue);border-color:var(--blue);color:#fff}
.prop-badge{width:14px;height:14px;border-radius:3px;font-size:0.62rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.rarity-bar{width:3px;height:14px;border-radius:2px;flex-shrink:0}
.radio-item{display:flex;align-items:center;gap:0.5rem;padding:0.22rem 0;cursor:pointer;font-size:0.8rem;color:var(--text2);transition:color .15s}
.radio-item:hover{color:var(--text)}
.radio-dot{width:14px;height:14px;border-radius:50%;border:1.5px solid var(--border2);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .15s}
.radio-dot.checked{border-color:var(--blue)}
.radio-dot.checked::after{content:'';width:6px;height:6px;border-radius:50%;background:var(--blue);display:block}
.age-pills{display:flex;flex-wrap:wrap;gap:0.3rem;margin-top:0.3rem}
.age-pill{padding:0.2rem 0.5rem;background:var(--surface);border:1px solid var(--border);border-radius:20px;font-size:0.7rem;color:var(--text2);cursor:pointer;transition:all .15s}
.age-pill:hover,.age-pill.active{background:var(--surface2);border-color:var(--border2);color:var(--text)}
.sidebar-badge{min-width:16px;height:16px;background:var(--surface3);border-radius:4px;font-size:0.62rem;color:var(--text2);display:inline-flex;align-items:center;justify-content:center;padding:0 3px;margin-left:auto}

/* ── HERO BANNER ── */
.hero-banner{margin:1.25rem 1.25rem 0;border-radius:12px;overflow:hidden;background:linear-gradient(135deg,#1a2535 0%,#0f1c35 40%,#162535 70%,#1a2040 100%);padding:1.25rem 1.5rem;display:flex;align-items:center;gap:1rem;border:1px solid var(--border);position:relative;min-height:88px}
.hero-banner::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 70% 50%,rgba(59,158,255,0.12) 0%,transparent 70%)}
.hero-icon{width:52px;height:52px;border-radius:10px;overflow:hidden;flex-shrink:0;background:linear-gradient(135deg,#ff6b35,#f7c948);display:flex;align-items:center;justify-content:center;font-size:1.8rem}
.hero-text h2{font-size:1.2rem;font-weight:800;color:var(--text);margin-bottom:0.2rem}
.hero-text p{font-size:0.8rem;color:var(--text2)}

/* ── SEARCH & FILTERS BAR ── */
.search-bar-wrap{padding:0.9rem 1.25rem 0}
.search-row{display:flex;gap:0.6rem;align-items:center}
.search-game-icon{width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,#ff6b35,#f7c948);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;cursor:pointer}
.search-input-wrap{flex:1;position:relative}
.search-input{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:0.55rem 1rem;color:var(--text);font-family:'Outfit',sans-serif;font-size:0.85rem;outline:none;transition:border-color .15s}
.search-input:focus{border-color:var(--blue)}
.search-input::placeholder{color:var(--muted)}
.sort-btn{display:flex;align-items:center;gap:0.4rem;padding:0.55rem 0.9rem;background:var(--surface);border:1px solid var(--border);border-radius:8px;color:var(--text2);font-family:'Outfit',sans-serif;font-size:0.8rem;cursor:pointer;white-space:nowrap;transition:all .15s}
.sort-btn:hover{border-color:var(--border2);color:var(--text)}
.refresh-btn{width:36px;height:36px;background:var(--surface);border:1px solid var(--border);border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text2);font-size:0.9rem;transition:all .15s;flex-shrink:0}
.refresh-btn:hover{border-color:var(--border2);color:var(--text)}

/* ── FILTER PILLS ── */
.pills-row{display:flex;gap:0.4rem;padding:0.7rem 1.25rem;overflow-x:auto;scrollbar-width:none}
.pills-row::-webkit-scrollbar{display:none}
.pill{padding:0.28rem 0.75rem;border-radius:20px;font-size:0.78rem;font-weight:600;cursor:pointer;transition:all .15s;white-space:nowrap;border:1px solid var(--border);background:var(--surface);color:var(--text2)}
.pill:hover{border-color:var(--border2);color:var(--text)}
.pill.active{background:var(--blue);border-color:var(--blue);color:#fff}

/* ── ITEMS GRID ── */
.items-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:0.75rem;padding:0 1.25rem 1.25rem}
.item-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;overflow:hidden;cursor:pointer;transition:all .2s;position:relative}
.item-card:hover{border-color:var(--border2);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,0.4)}
.card-img-wrap{aspect-ratio:1;background:linear-gradient(135deg,#1a2030,#0f1520);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;font-size:3rem}
.card-img-wrap::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 100%,rgba(59,158,255,0.08),transparent 70%)}
.card-bookmark{position:absolute;top:6px;right:6px;width:24px;height:24px;border-radius:5px;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;font-size:0.7rem;color:var(--text2);border:1px solid var(--border);transition:all .15s;z-index:2}
.card-bookmark:hover{color:var(--yellow);border-color:var(--yellow)}
.card-bookmark.wishlisted{color:var(--yellow);border-color:var(--yellow);background:rgba(255,209,102,0.15)}
.card-body{padding:0.6rem}
.card-category{display:flex;align-items:center;gap:0.25rem;font-size:0.66rem;color:var(--text2);margin-bottom:0.25rem}
.card-category-dot{width:5px;height:5px;border-radius:50%;background:var(--blue)}
.card-name{font-size:0.82rem;font-weight:700;color:var(--text);margin-bottom:0.35rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.card-price{font-size:1rem;font-weight:800;color:var(--text);margin-bottom:0.5rem}
.card-price span{color:var(--blue);font-size:0.75rem;margin-right:1px}
.card-actions{display:flex;gap:0.4rem}
.btn-buy{flex:1;padding:0.38rem;background:var(--blue);border:none;border-radius:6px;color:#fff;font-family:'Outfit',sans-serif;font-size:0.76rem;font-weight:700;cursor:pointer;transition:all .15s}
.btn-buy:hover{background:var(--blue2)}
.btn-cart{width:30px;height:28px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:0.75rem;color:var(--text2);transition:all .15s}
.btn-cart:hover{border-color:var(--border2);color:var(--text)}
.out-of-stock .btn-buy{background:var(--surface2);color:var(--muted);cursor:not-allowed}
.rarity-indicator{position:absolute;top:0;left:0;right:0;height:2px}

/* ── REVIEWS SECTION ── */
.reviews-section{padding:3rem 1.25rem;background:var(--bg2);border-top:1px solid var(--border);margin-top:1rem}
.reviews-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;flex-wrap:gap}
.reviews-title h2{font-size:2rem;font-weight:800}
.reviews-title h2 span{color:var(--blue)}
.trustpilot-badge{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:0.75rem 1rem;display:flex;align-items:center;gap:0.5rem}
.tp-star{color:var(--yellow);font-size:0.9rem}
.tp-info strong{font-size:0.9rem;font-weight:700}
.tp-info small{font-size:0.7rem;color:var(--text2);display:block}
.reviews-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1rem}
.review-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1rem;transition:border-color .15s}
.review-card:hover{border-color:var(--border2)}
.review-card.featured{border-color:var(--blue);background:var(--surface2)}
.reviewer{display:flex;align-items:center;gap:0.6rem;margin-bottom:0.6rem}
.reviewer-avatar{width:32px;height:32px;border-radius:50%;background:var(--surface3);display:flex;align-items:center;justify-content:center;font-size:0.8rem;overflow:hidden}
.reviewer-name{font-size:0.82rem;font-weight:700}
.reviewer-stars{display:flex;gap:1px;margin-left:auto}
.reviewer-stars span{color:var(--yellow);font-size:0.72rem}
.reviewer-country{font-size:0.7rem;color:var(--text2)}
.review-text{font-size:0.77rem;color:var(--text2);line-height:1.5}

/* ── FOOTER ── */
footer{background:var(--bg2);border-top:1px solid var(--border);padding:2rem 1.5rem 1.5rem}
.footer-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:2rem;margin-bottom:1.5rem}
.footer-brand .logo{font-size:1rem;margin-bottom:0.5rem;display:inline-flex}
.footer-brand p{font-size:0.77rem;color:var(--text2);line-height:1.6}
.footer-col h4{font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(--text2);margin-bottom:0.75rem}
.footer-col a{display:block;font-size:0.8rem;color:var(--text2);text-decoration:none;margin-bottom:0.4rem;transition:color .15s;cursor:pointer}
.footer-col a:hover{color:var(--text)}
.footer-socials{display:flex;gap:0.5rem}
.social-icon{width:32px;height:32px;background:var(--surface);border:1px solid var(--border);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:0.8rem;cursor:pointer;transition:all .15s}
.social-icon:hover{border-color:var(--border2);background:var(--surface2)}
.footer-bottom{border-top:1px solid var(--border);padding-top:1rem;display:flex;align-items:center;justify-content:space-between}
.footer-bottom p{font-size:0.75rem;color:var(--muted)}
.footer-logo-small{font-size:0.8rem;font-weight:800;color:var(--text2);display:flex;align-items:center;gap:0.3rem}
.footer-logo-small .logo-box{width:18px;height:18px;font-size:0.55rem;border-radius:4px}

/* ══════════════════════════════
   AFFILIATE PAGE
══════════════════════════════ */
.page-body{flex:1;padding:1.5rem}
.aff-hero{background:linear-gradient(135deg,#0f1b35 0%,#0c1a30 50%,#0f1525 100%);border-radius:12px;border:1px solid var(--border);padding:2rem;display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;position:relative;overflow:hidden}
.aff-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 80% 50%,rgba(59,158,255,0.15),transparent 60%)}
.aff-hero-text h1{font-size:1.8rem;font-weight:900;margin-bottom:0.5rem}
.aff-hero-text p{font-size:0.85rem;color:var(--text2);max-width:420px;line-height:1.6}
.aff-dollar{width:80px;height:80px;border-radius:50%;background:rgba(59,158,255,0.15);border:2px solid rgba(59,158,255,0.3);display:flex;align-items:center;justify-content:center;font-size:2rem;flex-shrink:0;position:relative;z-index:1}
.btn-partner{display:inline-flex;align-items:center;gap:0.4rem;margin-top:1rem;padding:0.6rem 1.2rem;background:var(--blue);border:none;color:#fff;font-family:'Outfit',sans-serif;font-size:0.85rem;font-weight:700;border-radius:8px;cursor:pointer;transition:all .15s}
.btn-partner:hover{background:var(--blue2);box-shadow:0 0 16px var(--blue-glow)}
