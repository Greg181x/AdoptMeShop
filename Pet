.sc-input{flex:1;background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:0.4rem 0.6rem;color:var(--text2);font-family:'Outfit',sans-serif;font-size:0.75rem;outline:none;max-width:200px}
.btn-verify{padding:0.38rem 0.85rem;background:var(--orange);border:none;border-radius:6px;color:#fff;font-family:'Outfit',sans-serif;font-size:0.78rem;font-weight:700;cursor:pointer;transition:all .15s;white-space:nowrap}
