function doCheckout() {
  if(!cart.length) return;
  cart.forEach(item => {
    if(!inventory.find(i => i.id === item.pet.id)) inventory.push(item.pet);
  });
  cart = [];
  updateCartBadge();
  showToast('🎉', 'Purchase complete! Check your Inventory.');
  renderCart();
}

