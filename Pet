function renderGrid(data){
  const grid=document.getElementById('items-grid');
  if(!data.length){
    grid.innerHTML=`<div class="no-results" style="grid-column:1/-1"><div class="no-results-icon">🔍</div><h3>No pets found</h3><p style="font-size:0.78rem;margin-top:0.25rem">Try adjusting your filters</p></div>`;
    return;
  }
  grid.innerHTML=data.map(p=>{
    const rc=rarityColors[p.rarity]||'#8b90a8';
    const rb=rarityBg[p.rarity]||'';
    const wishlisted=wishlist.includes(p.id);
    return `<div class="item-card${!p.stock?' out-of-stock':''}" onclick="openDetail(${p.id})">
      <div class="rarity-indicator" style="background:${rc}"></div>
      <div class="card-img-wrap" style="background:${rb}">
        <img src="${p.img}" alt="${p.name}" referrerpolicy="no-referrer" style="width:80%;height:80%;object-fit:contain;position:relative;z-index:1" onerror="this.style.display='none';this.nextSibling.style.display='block'" loading="lazy">
        <span style="font-size:3rem;position:relative;z-index:1;display:none">${p.emoji}</span>
        <div class="card-bookmark${wishlisted?' wishlisted':''}" onclick="event.stopPropagation();toggleWishlist(${p.id},this)">${wishlisted?'♥':'♡'}</div>
      </div>
      <div class="card-body">
        <div class="card-category"><div class="card-category-dot"></div>Adopt Me Pets</div>
        <div class="card-name">${p.name}</div>
        <div class="card-price"><span>$</span>${p.price}.00</div>
        <div class="card-actions">
          <button class="btn-buy" onclick="event.stopPropagation();addToCart(${p.id})">${p.stock?'Buy Now':'Out of Stock'}</button>
          <div class="btn-cart" onclick="event.stopPropagation();addToCart(${p.id})" title="Add to cart">🛒</div>
        </div>
      </div>
    </div>`;
  }).join('');
  updateRarityCounts();
}

function updateRarityCounts(){
  ['common','uncommon','rare','ultra','legendary','neon'].forEach(r=>{
    const el=document.getElementById('cnt-'+r);
    if(el){
      const key=r==='ultra'?'ultra-rare':r;
      el.textContent=pets.filter(p=>p.rarity===key).length;
    }
  });
}

// ══════════════════════════════
//  FILTER LOGIC
// ══════════════════════════════
function applyFilters(){
  const search=(document.getElementById('search')?.value||'').toLowerCase();

  let data=pets.filter(p=>{
    if(search&&!p.name.toLowerCase().includes(search)) return false;
    if(p.price<priceMin||p.price>priceMax) return false;
    if(pillFilter&&p.rarity!==pillFilter) return false;
    if(filterTypeRarity&&p.rarity!==filterTypeRarity) return false;
    if(filterRarities.size&&!filterRarities.has(p.rarity)) return false;
    if(filterProps.has('flyable')&&!p.flyable) return false;
    if(filterProps.has('rideable')&&!p.rideable) return false;
    if(filterProps.has('neon')&&p.rarity!=='neon') return false;
    if(filterProps.has('mega')&&p.rarity!=='neon') return false;
    if(filterProps.has('common')&&p.rarity!=='common') return false;
    if(filterAges.size&&!filterAges.has(p.age)) return false;
    if(filterFlyOnly&&!p.flyable) return false;
    if(filterRideOnly&&!p.rideable) return false;
    return true;
  });

  if(sortMode==='price-asc') data.sort((a,b)=>a.price-b.price);
  else if(sortMode==='price-desc') data.sort((a,b)=>b.price-a.price);
  else if(sortMode==='demand') data.sort((a,b)=>b.offers-a.offers);

  renderGrid(data);
}

function setPill(rarity,el){
  document.querySelectorAll('.pill').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  pillFilter=rarity==='all'?'':rarity;
  applyFilters();
}

function toggleProp(prop,el){
  const box=el.querySelector('.check-box');
  if(filterProps.has(prop)){filterProps.delete(prop);box.classList.remove('checked');box.textContent='';}
  else{filterProps.add(prop);box.classList.add('checked');box.textContent='✓';}
  applyFilters();
}

function toggleRarity(rarity,el){
  const box=el.querySelector('.check-box');
  if(filterRarities.has(rarity)){filterRarities.delete(rarity);box.classList.remove('checked');box.textContent='';}
  else{filterRarities.add(rarity);box.classList.add('checked');box.textContent='✓';}
  applyFilters();
}

function toggleAge(age,el){
  el.classList.toggle('active');
  if(filterAges.has(age)) filterAges.delete(age);
  else filterAges.add(age);
  applyFilters();
}

function setType(type,el){
  document.querySelectorAll('.radio-item .radio-dot').forEach(d=>d.classList.remove('checked'));
  el.querySelector('.radio-dot').classList.add('checked');
  filterTypeRarity=type==='all'?'':type;
  applyFilters();
}

function filterFlyable(el){
  el.classList.toggle('active');
  filterFlyOnly=el.classList.contains('active');
  applyFilters();
}

function filterRideable(el){
  el.classList.toggle('active');
  filterRideOnly=el.classList.contains('active');
  applyFilters();
}

function resetAllFilters(){
  filterRarities.clear(); filterProps.clear(); filterAges.clear();
  filterTypeRarity=''; pillFilter=''; filterFlyOnly=false; filterRideOnly=false;
  document.getElementById('search').value='';
  resetPriceFilter();
  document.querySelectorAll('.pill').forEach(p=>p.classList.remove('active'));
  document.getElementById('pill-all').classList.add('active');
  document.querySelectorAll('.check-box').forEach(b=>{b.classList.remove('checked');b.textContent='';});
  document.querySelectorAll('.age-pill').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.radio-dot').forEach(d=>d.classList.remove('checked'));
  document.querySelector('#type-all .radio-dot').classList.add('checked');
  applyFilters();
}

function toggleSort(){
  const modes=['price-desc','price-asc','demand'];
  const labels=['Discount: Max','Price: Low','Most Demanded'];
  const idx=(modes.indexOf(sortMode)+1)%modes.length;
  sortMode=modes[idx];
  document.getElementById('sort-label').textContent=labels[idx];
  applyFilters();
