.settings-section-title{display:flex;align-items:center;gap:0.5rem;font-size:0.82rem;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:0.07em;margin-bottom:1rem}
.settings-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.75rem}
.form-group{display:flex;flex-direction:column;gap:0.3rem}
.form-group label{font-size:0.72rem;color:var(--text2)}
.form-input-settings{background:var(--bg);border:1px solid var(--border);border-radius:7px;padding:0.5rem 0.75rem;color:var(--text);font-family:'Outfit',sans-serif;font-size:0.82rem;outline:none;transition:border-color .15s;display:flex;align-items:center;gap:0.4rem}
.form-input-settings input{background:transparent;border:none;outline:none;color:var(--text);font-family:'Outfit',sans-serif;font-size:0.82rem;width:100%}
.form-input-settings:focus-within{border-color:var(--blue)}
.form-icon{font-size:0.75rem;color:var(--muted)}
.social-connect-card{background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:0.75rem 1rem;display:flex;align-items:center;gap:0.75rem}
.sc-icon{width:36px;height:36px;border-radius:8px;background:#1877f2;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
