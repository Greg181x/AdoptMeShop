.form-label-sm{font-size:0.72rem;color:var(--text2);margin-bottom:0.3rem;display:block}
.select-input{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:7px;padding:0.5rem 0.75rem;color:var(--text);font-family:'Outfit',sans-serif;font-size:0.82rem;outline:none;appearance:none;cursor:pointer;margin-bottom:0.75rem}
