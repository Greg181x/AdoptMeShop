// ── DUAL RANGE SLIDER ────────────────────────────────────────────────────────
function updateRangeFill() {
  const min = parseInt(document.getElementById('rangeMin').value);
  const max = parseInt(document.getElementById('rangeMax').value);
  const pct1 = (min / PRICE_MAX) * 100;
  const pct2 = (max / PRICE_MAX) * 100;
  document.getElementById('rangeFill').style.left  = pct1 + '%';
  document.getElementById('rangeFill').style.width = (pct2 - pct1) + '%';
}
function onRangeMin() {
  const minEl = document.getElementById('rangeMin'), maxEl = document.getElementById('rangeMax');
  if(parseInt(minEl.value) > parseInt(maxEl.value)) minEl.value = maxEl.value;
  document.getElementById('priceFrom').value = minEl.value;
  updateRangeFill(); applyAllFilters();
}
function onRangeMax() {
  const minEl = document.getElementById('rangeMin'), maxEl = document.getElementById('rangeMax');
  if(parseInt(maxEl.value) < parseInt(minEl.value)) maxEl.value = minEl.value;
  document.getElementById('priceTo').value = maxEl.value;
  updateRangeFill(); applyAllFilters();
}
function syncSliderFromInputs() {
  let from = parseInt(document.getElementById('priceFrom').value)||0;
  let to   = parseInt(document.getElementById('priceTo').value)||PRICE_MAX;
  from = Math.max(0, Math.min(from, PRICE_MAX)); to = Math.max(0, Math.min(to, PRICE_MAX));
  if(from > to) from = to;
  document.getElementById('rangeMin').value = from; document.getElementById('rangeMax').value = to;
  updateRangeFill(); applyAllFilters();
}

// ── RARITY COUNTS ─────────────────────────────────────────────────────────────
function updateRarityCounts() {
  ['common','uncommon','rare','ultra-rare','legendary','neon'].forEach(r => {
    const el = document.getElementById('cnt-'+r);
    if(el) el.textContent = pets.filter(p => p.rarity === r).length;
  });
}

// ── FILTERS ───────────────────────────────────────────────────────────────────
function applyAllFilters() {
  const q = document.getElementById('searchInput').value.trim().toLowerCase();
  const priceFrom = parseFloat(document.getElementById('priceFrom').value)||0;
  const priceTo   = parseFloat(document.getElementById('priceTo').value)||Infinity;
  let data = pets.filter(p => {
    if(q && !p.name.toLowerCase().includes(q)) return false;
    if(p.price < priceFrom || p.price > priceTo) return false;
    if(topFilter === 'hot'  && !p.stock)    return false;
    if(topFilter === 'fly'  && !p.flyable)  return false;
    if(topFilter === 'ride' && !p.rideable) return false;
    if(['legendary','ultra-rare','rare','neon','common'].includes(topFilter) && p.rarity !== topFilter) return false;
    if(activeProps.size > 0) {
      const match = activeProps.has('default') || (activeProps.has('neon') && p.rarity==='neon') ||
        (activeProps.has('mega') && p.rarity==='neon') || (activeProps.has('fly') && p.flyable) || (activeProps.has('ride') && p.rideable);
      if(!match) return false;
    }
    if(activeRarities.size > 0 && !activeRarities.has(p.rarity)) return false;
    if(activeAge && p.age !== activeAge) return false;
    return true;
  });
  if(currentSort==='price-asc')  data.sort((a,b)=>a.price-b.price);
  else if(currentSort==='price-desc') data.sort((a,b)=>b.price-a.price);
  else if(currentSort==='newest') data.sort((a,b)=>b.id-a.id);
  else data.sort((a,b)=>b.offers-a.offers);
  renderCards(data); renderActiveFilters();
}

function setTopFilter(filter, el) {
  topFilter = filter;
  document.querySelectorAll('.filter-bar .pill').forEach(p=>p.classList.remove('active'));
  el.classList.add('active'); applyAllFilters();
}
function toggleProp(prop) {
  const box = document.getElementById('prop-'+prop);
  if(activeProps.has(prop)){activeProps.delete(prop);box.classList.remove('checked');}
  else{activeProps.add(prop);box.classList.add('checked');}
  applyAllFilters();
}
function resetProperties() {
  activeProps.clear();
  ['default','neon','mega','fly','ride'].forEach(p=>{const b=document.getElementById('prop-'+p);if(b)b.classList.remove('checked');});
  applyAllFilters();
}
function toggleRarity(r) {
  const box = document.getElementById('rar-'+r);
  if(activeRarities.has(r)){activeRarities.delete(r);box.classList.remove('checked');}
  else{activeRarities.add(r);box.classList.add('checked');}
  applyAllFilters();
}
function resetRarities() {
  activeRarities.clear();
  ['common','uncommon','rare','ultra-rare','legendary','neon'].forEach(r=>{const b=document.getElementById('rar-'+r);if(b)b.classList.remove('checked');});
  applyAllFilters();
}
function selectAge(age, el) {
  if(activeAge===age){activeAge=null;el.classList.remove('active');}
  else{if(activeAge){const old=document.getElementById('age-'+activeAge);if(old)old.classList.remove('active');}activeAge=age;el.classList.add('active');}
  applyAllFilters();
}
function resetAge() {
  if(activeAge){const old=document.getElementById('age-'+activeAge);if(old)old.classList.remove('active');}
  activeAge=null; applyAllFilters();
}
function resetPriceFilter() {
  document.getElementById('priceFrom').value=0; document.getElementById('priceTo').value=1000;
  document.getElementById('rangeMin').value=0; document.getElementById('rangeMax').value=1000;
  updateRangeFill(); applyAllFilters();
}

function renderActiveFilters() {
  const cont = document.getElementById('activeFilters'); if(!cont) return;
  const tags = [];
  if(topFilter !== 'all' && topFilter !== 'hot') tags.push({ label: topFilter, key: 'top' });
  activeRarities.forEach(r => tags.push({ label: rarityLabel[r]||r, key:'rar-'+r }));
  activeProps.forEach(p => tags.push({ label: p, key:'prop-'+p }));
  if(activeAge) tags.push({ label: activeAge, key:'age' });
  const from = parseInt(document.getElementById('priceFrom').value)||0;
  const to   = parseInt(document.getElementById('priceTo').value)||PRICE_MAX;
  if(from > 0 || to < PRICE_MAX) tags.push({ label: formatPrice(from)+' – '+formatPrice(to), key:'price' });
  cont.innerHTML = tags.map(t => `<span class="active-filter-tag" onclick="removeFilter('${t.key}')">${t.label} <span class="remove-tag">✕</span></span>`).join('');
  document.getElementById('sortLabel').textContent = 'Sorting: ' +
    (currentSort==='price-asc'?'Price ↑':currentSort==='price-desc'?'Price ↓':currentSort==='newest'?'Newest':'🔥 Popular first');
}

function removeFilter(key) {
  if(key==='top'){ topFilter='all'; document.querySelectorAll('.filter-bar .pill').forEach(p=>p.classList.remove('active')); document.getElementById('pill-all').classList.add('active'); }
  else if(key.startsWith('rar-')){ const r=key.slice(4); activeRarities.delete(r); const b=document.getElementById('rar-'+r); if(b)b.classList.remove('checked'); }
  else if(key.startsWith('prop-')){ const p=key.slice(5); activeProps.delete(p); const b=document.getElementById('prop-'+p); if(b)b.classList.remove('checked'); }
  else if(key==='age'){ resetAge(); return; }
  else if(key==='price'){ resetPriceFilter(); return; }
  applyAllFilters();
}

function generateStars(color) {
  return Array.from({length:6},(_,i)=>`<svg class="star-svg" style="left:${10+i*15}%;top:${10+((i*37)%70)}%;width:${8+i%3*4}px;height:${8+i%3*4}px;opacity:${0.3+i%3*0.15}" viewBox="0 0 24 24" fill="${color}"><polygon points="12,2 15,9 22,9 17,14 19,21 12,17 5,21 7,14 2,9 9,9"/></svg>`).join('');
}
function formatPrice(n) { return '€' + Number(n).toLocaleString(); }

function renderCards(data) {
  const grid = document.getElementById('cardsGrid');
  document.getElementById('countBadge').textContent = data.length + ' items';
  if(!data.length){ grid.innerHTML=`<div class="no-results"><div class="no-results-emoji">🔍</div><h3>No pets found</h3><p>Try adjusting your filters or search query.</p></div>`; return; }
  grid.innerHTML = data.map(p => {
    const sc = starAccents[p.rarity]||'#7c4dff';
    const inWl = wishlist.includes(p.id);
    return `
    <div class="pet-card ${!p.stock?'out-of-stock':''}" onclick="openModal(${p.id})">
      <div class="card-img" style="background:${p.bg}">
        <div class="card-img-stars">${generateStars(sc)}</div>
        <button class="wishlist-btn ${inWl?'wishlisted':''}" data-id="${p.id}" onclick="event.stopPropagation();toggleWishlist(${p.id},this)">${inWl?'❤️':'🤍'}</button>
        <img class="card-img-pet" src="${p.imgUrl}" alt="${p.name}" onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
        <span class="card-img-emoji">${p.emoji}</span>
        ${!p.stock?'<div class="hot-badge">Sold Out</div>':'<div class="hot-badge">Hot Price</div>'}
      </div>
      <div class="card-info">
        <div class="card-price-row"><div class="price-main">${formatPrice(p.price)}</div><div class="price-old">${formatPrice(Math.round(p.price*1.43))}</div></div>
        <div class="card-name">${p.name}</div>
        <div class="card-rarity-row">
          <span class="neon-badge" style="background:${rarityNeonColor[p.rarity]}">${p.rarity==='neon'?'N':p.rarity==='legendary'?'L':p.rarity==='ultra-rare'?'U':p.rarity==='rare'?'R':'C'}</span>
          <span class="rarity-badge ${rarityClass[p.rarity]}">${rarityLabel[p.rarity]}</span>
          ${p.flyable?'<span style="font-size:0.7rem;color:#3b82f6;font-weight:700;">🦅</span>':''}
          ${p.rideable?'<span style="font-size:0.7rem;color:#15803d;font-weight:700;">🐴</span>':''}
        </div>
        <button class="add-to-cart" onclick="event.stopPropagation();addToCart(${p.id})">🛒 ${p.stock?'Add to Cart':'Out of Stock'}</button>
      </div>
    </div>`;
  }).join('');
}

// ── WISHLIST TOGGLE ───────────────────────────────────────────────────────────
function toggleWishlist(id, btn) {
  if(!currentUser) { openAuthModal('login'); showToast('⚠️','Please log in to save pets.'); return; }
  if(wishlist.includes(id)) {
    wishlist = wishlist.filter(x => x !== id);
    if(btn){ btn.textContent='🤍'; btn.classList.remove('wishlisted'); }
    showToast('🤍', 'Removed from wishlist');
  } else {
    wishlist.push(id);
    if(btn){ btn.textContent='❤️'; btn.classList.add('wishlisted'); }
    showToast('❤️', 'Added to wishlist!');
  }
  updateWishlistBadge();
}

// ── ADD TO CART ───────────────────────────────────────────────────────────────
function addToCart(id) {
  if(!currentUser) { openAuthModal('login'); showToast('⚠️','Please log in to add to cart.'); return; }
  const p = pets.find(x => x.id === id); if(!p || !p.stock) return;
  const existing = cart.find(i => i.pet.id === id);
  if(existing) existing.qty++; else cart.push({ pet:p, qty:1 });
  updateCartBadge();
  showToast('🛒', p.name + ' added to cart!');
}

// ── MODAL ─────────────────────────────────────────────────────────────────────
function openModal(id) {
  const p = pets.find(x => x.id === id); if(!p) return;
  const mi = document.getElementById('modalPetImg'), me = document.getElementById('modalEmoji');
  mi.src = p.imgUrl; mi.alt = p.name; mi.style.display = 'none'; me.textContent = p.emoji; me.style.display = 'block';
  mi.onload = () => { mi.style.display='block'; me.style.display='none'; };
  mi.onerror = () => { mi.style.display='none'; me.style.display='block'; };
  document.getElementById('modalBg').style.background = p.bg;
  document.getElementById('modalName').textContent  = p.name;
  document.getElementById('modalPrice').textContent = formatPrice(p.price);
  document.getElementById('mAge').textContent    = p.age;
  document.getElementById('mDemand').textContent = p.demand;
  document.getElementById('mOffers').textContent = p.offers;
  document.getElementById('modalTags').innerHTML = `<span class="rarity-badge ${rarityClass[p.rarity]}">${rarityLabel[p.rarity]}</span>${p.flyable?'<span class="rarity-badge rb-common">🦅 Flyable</span>':''}${p.rideable?'<span class="rarity-badge rb-rare">🐴 Rideable</span>':''}`;
  const h = Array.from({length:14},()=>Math.round(8+Math.random()*28));
  document.getElementById('sparkline').innerHTML = h.map(v=>`<div class="spark-bar" style="height:${v}px"></div>`).join('');
  const b = document.getElementById('modalBuyBtn');
  b.textContent = p.stock ? `🛒 Buy for ${formatPrice(p.price)}` : 'Out of Stock';
  b.onclick = p.stock ? () => { closeModal(); addToCart(p.id); } : null;
  b.style.opacity = p.stock?'1':'0.5'; b.style.cursor = p.stock?'pointer':'not-allowed';
  document.getElementById('modalOverlay').classList.add('open');
}
function closeModal() { document.getElementById('modalOverlay').classList.remove('open'); }

// ── AUTH ──────────────────────────────────────────────────────────────────────
function openAuthModal(tab) { switchTab(tab||'login'); document.getElementById('authOverlay').classList.add('open'); }
function closeAuthModal()   { document.getElementById('authOverlay').classList.remove('open'); }
function switchTab(tab) {
  const l = tab==='login';
  document.getElementById('formLogin').style.display  = l?'block':'none';
  document.getElementById('formSignup').style.display = l?'none':'block';
  document.getElementById('tabLogin').className  = 'auth-tab '+(l?'active':'inactive');
  document.getElementById('tabSignup').className = 'auth-tab '+(l?'inactive':'active');
}
function togglePass(id){ const e=document.getElementById(id); e.type=e.type==='password'?'text':'password'; }
function clearError(id){ document.getElementById(id).style.display='none'; }

function doLogin() {
  const em=document.getElementById('loginEmail').value.trim(), pw=document.getElementById('loginPass').value, err=document.getElementById('loginError');
  if(!em||!pw){ err.textContent='⚠️ Please fill in all fields.'; err.style.display='block'; return; }
  if(pw.length<4){ err.textContent='⚠️ Password too short.'; err.style.display='block'; return; }
  currentUser = { username: em.includes('@') ? em.split('@')[0] : em };
  closeAuthModal(); updateNavLoggedIn(); showToast('✅', 'Welcome back, ' + currentUser.username + '!');
}
function doSignup() {
  const u=document.getElementById('signupUser').value.trim(), em=document.getElementById('signupEmail').value.trim(), pw=document.getElementById('signupPass').value, err=document.getElementById('signupError');
  if(!u||!em||!pw){ err.textContent='⚠️ Please fill in all required fields.'; err.style.display='block'; return; }
  if(pw.length<6){ err.textContent='⚠️ Password must be at least 6 characters.'; err.style.display='block'; return; }
  if(!em.includes('@')){ err.textContent='⚠️ Please enter a valid email.'; err.style.display='block'; return; }
  currentUser = { username: u }; closeAuthModal(); updateNavLoggedIn(); showToast('🎉', 'Account created! Welcome, ' + u + '!');
}

function updateNavLoggedIn() {
  document.getElementById('headerRight').innerHTML = `
    <div class="header-nav-icons">
      <button class="hni-btn" title="Inventory" onclick="showPage('inventory', null)">
        <span class="hni-icon">🎒</span><span class="hni-label">Inventory</span>
      </button>
      <button class="hni-btn" title="Wishlist" onclick="showPage('wishlist', null)">
        <span class="hni-icon">❤️</span><span class="hni-label">Wishlist</span>
        <span class="hni-badge" id="wlBadge" style="display:none">0</span>
      </button>
      <button class="hni-btn" title="Cart" onclick="showPage('cart', null)">
        <span class="hni-icon">🛒</span><span class="hni-label">Cart</span>
        <span class="hni-badge" id="cartBadge" style="display:none">0</span>
      </button>
    </div>
    <div class="hni-avatar" title="${currentUser.username}">😊</div>
    <div class="coins-badge">0</div>
    <button class="btn btn-primary" onclick="openSellModal()">+ Sell Pet</button>`;
}

// ── SELL ──────────────────────────────────────────────────────────────────────
function openSellModal() {
  if(!currentUser){ openAuthModal('login'); showToast('⚠️','Please log in to sell pets.'); return; }
  sellTags=[];
  ['tagFly','tagRide','tagNeon','tagMega'].forEach(id=>{const e=document.getElementById(id);if(e)e.className='tag-toggle';});
  ['sellName','sellEmoji','sellPrice','sellDesc'].forEach(id=>{document.getElementById(id).value='';});
  document.getElementById('sellRarity').value=''; document.getElementById('sellAge').value='';
  document.getElementById('sellError').style.display='none';
  updateSellPreview(); document.getElementById('sellOverlay').classList.add('open');
}
function closeSellModal() { document.getElementById('sellOverlay').classList.remove('open'); }
function toggleSellTag(el,tag){ const i=sellTags.indexOf(tag);if(i>-1){sellTags.splice(i,1);el.className='tag-toggle';}else{sellTags.push(tag);el.className='tag-toggle on';} }
function updateSellPreview() {
  const n=document.getElementById('sellName').value||'Your Pet',e=document.getElementById('sellEmoji').value||'🐾',r=document.getElementById('sellRarity').value,p=document.getElementById('sellPrice').value;
  document.getElementById('sellPreviewEmoji').textContent=e;
  document.getElementById('sellPreviewName').textContent=n;
  document.getElementById('sellPreviewRarity').textContent=r?rarityLabel[r]||r:'Select rarity';
  document.getElementById('sellPreviewPrice').textContent=p?'€'+Number(p).toLocaleString():'';
}
function doListPet() {
  const n=document.getElementById('sellName').value.trim(),e=document.getElementById('sellEmoji').value.trim(),r=document.getElementById('sellRarity').value,a=document.getElementById('sellAge').value,p=parseInt(document.getElementById('sellPrice').value),err=document.getElementById('sellError');
  if(!n){err.textContent='⚠️ Pet name is required.';err.style.display='block';return;}
  if(!r){err.textContent='⚠️ Please select a rarity.';err.style.display='block';return;}
  if(!a){err.textContent='⚠️ Please select an age.';err.style.display='block';return;}
  if(!p||p<1){err.textContent='⚠️ Please enter a valid price.';err.style.display='block';return;}
  pets.unshift({id:pets.length+1,name:n,emoji:e||'🐾',imgUrl:CDN+n.toLowerCase().replace(/ /g,'_')+'.png',rarity:r,age:a,price:p,flyable:sellTags.includes('Fly'),rideable:sellTags.includes('Ride'),bg:'linear-gradient(135deg,#f3f4f6,#ede9fe)',demand:'New',offers:0,stock:true});
  closeSellModal(); updateRarityCounts(); applyAllFilters(); showToast('🚀',n+' listed for sale!');
}

// ── TOAST ─────────────────────────────────────────────────────────────────────
let toastTimer;
function showToast(icon, msg) {
  document.getElementById('toastIcon').textContent=icon; document.getElementById('toastMsg').textContent=msg;
  const t=document.getElementById('toast'); t.classList.add('show'); clearTimeout(toastTimer); toastTimer=setTimeout(()=>t.classList.remove('show'),3000);
}

document.addEventListener('keydown', e=>{if(e.key==='Escape'){closeModal();closeAuthModal();closeSellModal();}});

// ── INIT ──────────────────────────────────────────────────────────────────────
// Add ids to marketplace sections for show/hide
document.addEventListener('DOMContentLoaded', () => {
  const fb = document.querySelector('.filter-bar'); if(fb) fb.id='filterBar';
  const sb = document.querySelector('.search-bar'); if(sb) sb.id='searchBar';
  const lv = document.querySelector('.layout');     if(lv) lv.id='layoutView';
});
updateRarityCounts();
updateRangeFill();
applyAllFilters();
</script>
