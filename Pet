function addToCart(id){
  const pet=pets.find(p=>p.id===id);
  if(!pet||!pet.stock) return;
  const existing=cart.find(c=>c.pet.id===id);
  if(existing) existing.qty++;
  else cart.push({pet,qty:1});
  updateCartUI();
  showToast(`🛒 ${pet.name} added to cart!`);
  document.getElementById('cart-panel').classList.add('open');
}

function removeFromCart(id){
  cart=cart.filter(c=>c.pet.id!==id);
  updateCartUI();
}

function updateCartUI(){
  const count=cart.reduce((s,c)=>s+c.qty,0);
  // Show/hide cart dot on header cart icon
  const dot=document.getElementById('cart-dot');
  if(dot) dot.style.display=count>0?'block':'none';

  const body=document.getElementById('cart-body');
  const footer=document.getElementById('cart-footer');
  if(!cart.length){
    body.innerHTML='<div class="panel-empty"><div class="panel-empty-icon">🛒</div><div>Your cart is empty</div><small>Add pets to get started!</small></div>';
    footer.style.display='none';
    return;
  }
  const total=cart.reduce((s,c)=>s+c.pet.price*c.qty,0);
  body.innerHTML=cart.map(c=>`
    <div class="cart-item">
      <div class="cart-item-img" style="background:${rarityBg[c.pet.rarity]||'var(--surface2)'}">
        <img src="${c.pet.img}" alt="${c.pet.name}" referrerpolicy="no-referrer" style="width:100%;height:100%;object-fit:contain" onerror="this.outerHTML='<span style=font-size:1.5rem>${c.pet.emoji}</span>'">
      </div>
      <div style="flex:1">
        <div class="cart-item-name">${c.pet.name}</div>
        <div class="cart-item-meta">${c.pet.rarity}${c.pet.flyable?' · ✈':''}${c.pet.rideable?' · 🏇':''}</div>
      </div>
      <span class="cart-item-price">$${(c.pet.price*c.qty).toFixed(2)}</span>
      <button class="cart-item-remove" onclick="removeFromCart(${c.pet.id})">✕</button>
    </div>`).join('');
  document.getElementById('cart-total').textContent='$'+total.toFixed(2);
  footer.style.display='block';
}

function checkout(){
  showToast('💳 Redirecting to checkout...');
  navigate('deposit');
  document.getElementById('cart-panel').classList.remove('open');
}

