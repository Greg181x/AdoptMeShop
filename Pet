function submitSell(){
  const n=document.getElementById('sellName').value.trim();
  const r=document.getElementById('sellRarity').value;
  const a=document.getElementById('sellAge').value;
  const pr=parseFloat(document.getElementById('sellPrice').value);
  if(!n||!r||!a||!pr){document.getElementById('sellError').textContent='Please fill all required fields.';return;}
  const e=document.getElementById('sellEmojiInput').value||'🐾';
  pets.unshift({id:pets.length+1,name:n,emoji:e,rarity:r,age:a,price:pr,flyable:sellTags.includes('Fly'),rideable:sellTags.includes('Ride'),demand:'New',offers:0,stock:true});
