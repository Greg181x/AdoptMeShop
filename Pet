.support-hero h1{font-size:2.2rem;font-weight:900;margin-bottom:1rem}
.support-search{max-width:480px;margin:0 auto;position:relative}
.support-search input{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:0.7rem 1rem;color:var(--text);font-family:'Outfit',sans-serif;font-size:0.9rem;outline:none;transition:border-color .15s}
.support-search input:focus{border-color:var(--blue)}
.support-search input::placeholder{color:var(--muted)}
.search-result-note{font-size:0.78rem;color:var(--text2);margin-top:0.5rem}
.search-result-note span{color:var(--blue);font-weight:600}
.support-body{padding:1.5rem 2rem;display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;max-width:900px;margin:0 auto}
.accordion-item{background:var(--surface);border:1px solid var(--border);border-radius:9px;overflow:hidden;cursor:pointer;transition:border-color .15s}
.accordion-item:hover{border-color:var(--border2)}
.accordion-item.open{border-color:var(--blue)}
.accordion-header{display:flex;align-items:center;justify-content:space-between;padding:0.85rem 1rem;font-size:0.83rem;font-weight:600}
