function updateDualFill(){
  const track=document.querySelector('.dual-range-track');
  const fill=document.getElementById('dual-fill');
  if(!fill||!track) return;
  const pct1=(priceMin/10000)*100;
  const pct2=(priceMax/10000)*100;
  fill.style.left=pct1+'%';
  fill.style.width=(pct2-pct1)+'%';
}

function dualRangeMin(val){
  val=parseInt(val);
  if(val>=priceMax) val=priceMax-10;
  priceMin=val;
  document.getElementById('range-min').value=val;
  document.getElementById('price-min').value=val||'';
  updateDualFill();
  applyFilters();
}

function dualRangeMax(val){
  val=parseInt(val);
  if(val<=priceMin) val=priceMin+10;
  priceMax=val;
  document.getElementById('range-max').value=val;
  document.getElementById('price-max').value=val===10000?'':val;
  updateDualFill();
  applyFilters();
}

function onPriceMinInput(val){
  val=Math.max(0,Math.min(parseInt(val)||0,priceMax-10));
  priceMin=val;
  document.getElementById('range-min').value=val;
  updateDualFill();
  applyFilters();
}

function onPriceMaxInput(val){
  val=Math.min(10000,Math.max(parseInt(val)||10000,priceMin+10));
  priceMax=val;
  document.getElementById('range-max').value=val;
  updateDualFill();
  applyFilters();
}

function resetPriceFilter(){
  priceMin=0; priceMax=10000;
  document.getElementById('price-min').value='';
  document.getElementById('price-max').value='';
  document.getElementById('range-min').value=0;
  document.getElementById('range-max').value=10000;
  updateDualFill();
  applyFilters();
}

