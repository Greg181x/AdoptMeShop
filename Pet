.support-footer-note{text-align:center;padding:1rem;font-size:0.75rem;color:var(--muted);display:flex;align-items:center;justify-content:center;gap:0.35rem}

/* ══════════════════════════════
   MODALS / OVERLAYS
══════════════════════════════ */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:300;display:none;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
.overlay.show{display:flex}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:14px;width:460px;max-width:95vw;max-height:90vh;overflow-y:auto;animation:modalIn .2s ease}
@keyframes modalIn{from{opacity:0;transform:scale(0.95) translateY(10px)}to{opacity:1;transform:scale(1) translateY(0)}}
.modal-header{padding:1.25rem 1.25rem 0;display:flex;align-items:center;justify-content:space-between}
.modal-header h3{font-size:1rem;font-weight:800}
.modal-close{width:28px;height:28px;background:var(--surface2);border:1px solid var(--border);border-radius:7px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:0.8rem;color:var(--text2);transition:all .15s}
.modal-close:hover{background:var(--surface3);color:var(--text)}
.modal-body{padding:1.25rem}

/* ══════════════════════════════
   CART / WISHLIST PANELS
══════════════════════════════ */
.slide-panel{position:fixed;top:0;right:-420px;width:400px;height:100vh;background:var(--bg2);border-left:1px solid var(--border);z-index:250;transition:right .3s ease;display:flex;flex-direction:column}
.slide-panel.open{right:0}
.panel-header{padding:1.1rem 1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.panel-header h3{font-size:0.95rem;font-weight:800}
.panel-close{width:28px;height:28px;background:var(--surface);border:1px solid var(--border);border-radius:7px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:0.8rem;color:var(--text2)}
.panel-close:hover{background:var(--surface2);color:var(--text)}
.panel-body{flex:1;overflow-y:auto;padding:1rem}
.panel-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:0.5rem;color:var(--text2);font-size:0.85rem;text-align:center}
.panel-empty-icon{font-size:3rem;opacity:0.3;margin-bottom:0.5rem}
.panel-footer{padding:1rem 1.25rem;border-top:1px solid var(--border)}
.cart-item{display:flex;align-items:center;gap:0.75rem;padding:0.75rem 0;border-bottom:1px solid var(--border)}
.cart-item-img{width:46px;height:46px;border-radius:8px;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0}
.cart-item-name{font-size:0.85rem;font-weight:700}
.cart-item-meta{font-size:0.72rem;color:var(--text2)}
.cart-item-price{font-size:0.9rem;font-weight:700;margin-left:auto;white-space:nowrap}
.cart-item-remove{background:none;border:none;color:var(--muted);cursor:pointer;font-size:0.8rem;padding:0.2rem;transition:color .15s;margin-left:0.5rem}
.cart-item-remove:hover{color:var(--red)}
.cart-total-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem}
.cart-total-label{font-size:0.82rem;color:var(--text2)}
.cart-total-val{font-size:1.1rem;font-weight:800}
.btn-checkout{width:100%;padding:0.65rem;background:var(--blue);border:none;border-radius:8px;color:#fff;font-family:'Outfit',sans-serif;font-size:0.9rem;font-weight:700;cursor:pointer;transition:all .15s}
.btn-checkout:hover{background:var(--blue2);box-shadow:0 0 16px var(--blue-glow)}
.cart-badge{min-width:16px;height:16px;background:var(--blue);border-radius:8px;font-size:0.62rem;font-weight:800;color:#fff;display:inline-flex;align-items:center;justify-content:center;padding:0 4px;margin-left:4px}

/* ══════════════════════════════
   DETAIL MODAL
══════════════════════════════ */
.detail-modal{width:600px}
.detail-hero{background:linear-gradient(135deg,#1a2030,#0f1520);border-radius:10px;margin-bottom:1rem;padding:1.5rem;display:flex;align-items:center;gap:1.25rem}
.detail-img{width:90px;height:90px;border-radius:10px;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:3.5rem;flex-shrink:0}
.detail-info h2{font-size:1.3rem;font-weight:800;margin-bottom:0.25rem}
.detail-price{font-size:1.6rem;font-weight:900;color:var(--text)}
.detail-price .dollar{color:var(--blue);font-size:1rem}
.detail-tags{display:flex;gap:0.4rem;flex-wrap:wrap;margin-top:0.5rem}
.detail-tag{padding:0.2rem 0.55rem;background:var(--surface3);border-radius:20px;font-size:0.7rem;color:var(--text2)}
.detail-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.6rem;margin-bottom:1rem}
.detail-stat{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.6rem 0.75rem;text-align:center}
.detail-stat-val{font-size:1rem;font-weight:700;margin-bottom:0.1rem}
.detail-stat-label{font-size:0.65rem;color:var(--text2);text-transform:uppercase;letter-spacing:0.06em}
.sparkline-wrap{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.75rem;margin-bottom:1rem}
.sparkline-title{font-size:0.72rem;color:var(--text2);margin-bottom:0.5rem;text-transform:uppercase;letter-spacing:0.06em;font-weight:600}
.sparkline-svg{width:100%;height:60px}
.detail-actions{display:flex;gap:0.5rem}
.btn-detail-buy{flex:1;padding:0.65rem;background:var(--blue);border:none;border-radius:8px;color:#fff;font-family:'Outfit',sans-serif;font-size:0.9rem;font-weight:700;cursor:pointer;transition:all .15s}
.btn-detail-buy:hover{background:var(--blue2);box-shadow:0 0 14px var(--blue-glow)}
.btn-detail-cart{padding:0.65rem 1rem;background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Outfit',sans-serif;font-size:0.85rem;font-weight:600;cursor:pointer;transition:all .15s}
.btn-detail-cart:hover{background:var(--surface3);border-color:var(--border2)}

/* ══════════════════════════════
   TOAST
══════════════════════════════ */
#toast-container{position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;display:flex;flex-direction:column;gap:0.5rem}
.toast{background:var(--surface2);border:1px solid var(--border2);border-radius:9px;padding:0.65rem 1rem;font-size:0.82rem;font-weight:600;display:flex;align-items:center;gap:0.5rem;animation:toastIn .2s ease;box-shadow:0 4px 20px rgba(0,0,0,0.4)}
@keyframes toastIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:translateX(0)}}
.toast.fade-out{animation:toastOut .3s ease forwards}
@keyframes toastOut{to{opacity:0;transform:translateX(20px)}}

/* ══════════════════════════════
   SELL MODAL
══════════════════════════════ */
.sell-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.6rem}
.sell-input{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:7px;padding:0.5rem 0.75rem;color:var(--text);font-family:'Outfit',sans-serif;font-size:0.83rem;outline:none;transition:border-color .15s}
.sell-input:focus{border-color:var(--blue)}
.sell-input::placeholder{color:var(--muted)}
.sell-label{font-size:0.72rem;color:var(--text2);margin-bottom:0.3rem;display:block}
.sell-form-group{display:flex;flex-direction:column;margin-bottom:0.6rem}
.sell-preview-box{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.75rem;display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem}
.sell-preview-emoji{font-size:1.8rem}
.sell-preview-name{font-size:0.88rem;font-weight:700}
.sell-preview-rarity{font-size:0.72rem;color:var(--text2)}
.tag-row{display:flex;gap:0.4rem;flex-wrap:wrap}
.tag-btn{padding:0.25rem 0.65rem;background:var(--surface);border:1px solid var(--border);border-radius:20px;font-size:0.75rem;color:var(--text2);cursor:pointer;transition:all .15s}
.tag-btn:hover,.tag-btn.active{background:var(--blue);border-color:var(--blue);color:#fff}

/* ══════════════════════════════
   UTILITY
══════════════════════════════ */
.hidden{display:none!important}
.fade{animation:fadeIn .2s ease}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.no-results{text-align:center;padding:3rem 1rem;color:var(--text2)}
.no-results-icon{font-size:3rem;opacity:0.3;margin-bottom:0.5rem}
.no-results h3{font-size:1rem;font-weight:700;margin-bottom:0.3rem}
</style>
</head>
<body>

<!-- ══════════════════════════════
     PAGE: MARKETPLACE
══════════════════════════════ -->
<div class="page active" id="page-market">
  <!-- HEADER -->
  <header>
    <a class="logo" onclick="navigate('market')">
      <div class="logo-box">B</div>BloxBolt
    </a>
    <nav>
      <a onclick="navigate('market')" class="active" id="nav-market">
        <span class="dot"></span> Home
      </a>
      <a onclick="navigate('market')" id="nav-market2">
        <span style="display:inline-flex;align-items:center;gap:5px"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg> Market</span>
      </a>
      <a onclick="openSellModal()"><span style="display:inline-flex;align-items:center;gap:5px"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg> Instant Sell</span></a>
      <a onclick="navigate('affiliate')"><span style="display:inline-flex;align-items:center;gap:5px"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg> Affiliate</span></a>
      <a onclick="navigate('deposit')"><span class="nav-icon" style="display:inline-flex;align-items:center;gap:5px"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg> Deposit</span></a>
    </nav>
    <div class="header-actions" id="header-guest">
      <button class="refresh-btn" onclick="document.querySelector('.search-input').value='';applyFilters()" title="Clear search"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></button>
      <button class="btn-login" onclick="navigate('auth')">Log In</button>
      <button class="btn-signup" onclick="navigate('auth')">Sign Up</button>
    </div>
    <!-- POST LOGIN HEADER BAR -->
    <div class="header-actions hidden" id="header-loggedin" style="gap:0.4rem">
      <!-- Balance bar -->
      <div class="balance-bar">
        <span class="bal-icon">$</span>
        <span class="bal-amount" id="header-balance">582<span class="bal-cents">.00</span></span>
        <button class="bal-add" onclick="navigate('deposit')" title="Add funds">+</button>
      </div>
      <!-- Cart icon -->
      <div class="cart-icon-btn" onclick="document.getElementById('cart-panel').classList.add('open')" title="Cart">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        <span class="cart-dot" id="cart-dot" style="display:none"></span>
      </div>
      <!-- Avatar + chevron -->
      <div class="user-avatar-btn" onclick="navigate('profile')" title="Profile">
        <div class="avatar-fallback">😎</div>
      </div>
      <div class="chevron-btn" onclick="navigate('profile')">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
    </div>
  </header>

  <div class="layout">
    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div style="background:var(--blue);border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:800;margin-bottom:1rem">1</div>

      <div class="filter-section">
        <div class="filter-title">Price <span onclick="resetPriceFilter()">−</span></div>
        <div class="price-row">
          <div class="price-input-box">
            <span class="pi-dollar">$</span>
            <input type="number" id="price-min" placeholder="0" min="0" oninput="onPriceMinInput(this.value)">
          </div>
          <div class="price-input-box">
            <span class="pi-dollar">$</span>
            <input type="number" id="price-max" placeholder="10000" max="10000" oninput="onPriceMaxInput(this.value)">
          </div>
        </div>
        <!-- Dual range slider -->
        <div class="dual-range-wrap">
          <div class="dual-range-track"></div>
          <div class="dual-range-fill" id="dual-fill"></div>
          <input type="range" id="range-min" min="0" max="10000" value="0" step="10" oninput="dualRangeMin(this.value)">
          <input type="range" id="range-max" min="0" max="10000" value="10000" step="10" oninput="dualRangeMax(this.value)">
        </div>
      </div>

      <div class="filter-section">
        <div class="filter-title">Properties <span>−</span></div>
        <div class="check-item" onclick="toggleProp('common',this)">
          <div class="check-box" id="prop-common"></div>
          <span class="prop-badge" style="background:#8b90a8;color:#fff">C</span>Common
        </div>
        <div class="check-item" onclick="toggleProp('neon',this)">
          <div class="check-box" id="prop-neon"></div>
          <span class="prop-badge" style="background:#ff7a3d;color:#fff">N</span>Neon
        </div>
        <div class="check-item" onclick="toggleProp('mega',this)">
          <div class="check-box" id="prop-mega"></div>
          <span class="prop-badge" style="background:#b06aff;color:#fff">M</span>Mega Neon
        </div>
        <div class="check-item" onclick="toggleProp('flyable',this)">
          <div class="check-box" id="prop-flyable"></div>
          <span class="prop-badge" style="background:#3b9eff;color:#fff">F</span>Flyable
        </div>
        <div class="check-item" onclick="toggleProp('rideable',this)">
          <div class="check-box" id="prop-rideable"></div>
          <span class="prop-badge" style="background:#3dd68c;color:#111">R</span>Rideable
        </div>
      </div>

      <div class="filter-section">
        <div class="filter-title">Type <span>−</span></div>
        <div class="radio-item" onclick="setType('all',this)" id="type-all">
          <div class="radio-dot checked"></div>All
        </div>
        <div class="radio-item" onclick="setType('legendary',this)" id="type-legendary">
          <div class="radio-dot"></div>Legendary
        </div>
        <div class="radio-item" onclick="setType('ultra-rare',this)" id="type-ultra">
          <div class="radio-dot"></div>Ultra Rare
        </div>
        <div class="radio-item" onclick="setType('rare',this)" id="type-rare">
          <div class="radio-dot"></div>Rare
        </div>
      </div>

      <div class="filter-section">
        <div class="filter-title">Rarity <span>−</span></div>
        <div class="check-item" onclick="toggleRarity('common',this)">
          <div class="check-box" id="rar-common"></div>
          <div class="rarity-bar" style="background:var(--c-common)"></div>Common
          <span class="sidebar-badge" id="cnt-common">0</span>
        </div>
        <div class="check-item" onclick="toggleRarity('uncommon',this)">
          <div class="check-box" id="rar-uncommon"></div>
          <div class="rarity-bar" style="background:var(--c-uncommon)"></div>Uncommon
          <span class="sidebar-badge" id="cnt-uncommon">0</span>
        </div>
        <div class="check-item" onclick="toggleRarity('rare',this)">
          <div class="check-box" id="rar-rare"></div>
          <div class="rarity-bar" style="background:var(--c-rare)"></div>Rare
          <span class="sidebar-badge" id="cnt-rare">0</span>
        </div>
        <div class="check-item" onclick="toggleRarity('ultra-rare',this)">
          <div class="check-box" id="rar-ultra"></div>
          <div class="rarity-bar" style="background:var(--c-ultra)"></div>Ultra-Rare
          <span class="sidebar-badge" id="cnt-ultra">0</span>
        </div>
        <div class="check-item" onclick="toggleRarity('legendary',this)">
          <div class="check-box" id="rar-legendary"></div>
          <div class="rarity-bar" style="background:var(--c-legendary)"></div>Legendary
          <span class="sidebar-badge" id="cnt-legendary">0</span>
        </div>
        <div class="check-item" onclick="toggleRarity('neon',this)">
          <div class="check-box" id="rar-neon"></div>
          <div class="rarity-bar" style="background:var(--c-neon)"></div>Neon
          <span class="sidebar-badge" id="cnt-neon">0</span>
        </div>
      </div>

      <div class="filter-section">
        <div class="filter-title">Age <span>−</span></div>
        <div class="age-pills">
          <div class="age-pill" onclick="toggleAge('Newborn',this)">Newborn</div>
          <div class="age-pill" onclick="toggleAge('Junior',this)">Junior</div>
          <div class="age-pill" onclick="toggleAge('Pre-Teen',this)">Pre-Teen</div>
          <div class="age-pill" onclick="toggleAge('Teen',this)">Teen</div>
          <div class="age-pill" onclick="toggleAge('Post-Teen',this)">Post-Teen</div>
          <div class="age-pill" onclick="toggleAge('Full Grown',this)">Full Grown</div>
          <div class="age-pill" onclick="toggleAge('Reborn',this)">Reborn</div>
          <div class="age-pill" onclick="toggleAge('Twinkle',this)">Twinkle</div>
          <div class="age-pill" onclick="toggleAge('Sparkle',this)">Sparkle</div>
          <div class="age-pill" onclick="toggleAge('Flare',this)">Flare</div>
          <div class="age-pill" onclick="toggleAge('Luminous',this)">Luminous</div>
          <div class="age-pill" onclick="toggleAge('Sunshine',this)">Sunshine</div>
        </div>
      </div>
    </aside>

    <!-- MAIN -->
    <div class="main-content">
      <!-- Hero Banner -->
      <div class="hero-banner">
        <div class="hero-icon"><svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="12" x2="10" y2="12"/><line x1="8" y1="10" x2="8" y2="14"/><circle cx="15" cy="13" r="1" fill="currentColor"/><circle cx="17" cy="11" r="1" fill="currentColor"/><path d="M17 5H7a7 7 0 0 0 0 14h10a7 7 0 0 0 0-14z"/></svg></div>
        <div class="hero-text">
          <h2>Adopt Me</h2>
          <p>Buy and sell Adopt Me pets instantly with secure transactions</p>
        </div>
      </div>

      <!-- Search Bar -->
      <div class="search-bar-wrap">
        <div class="search-row">
          <div class="search-game-icon"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="12" x2="10" y2="12"/><line x1="8" y1="10" x2="8" y2="14"/><circle cx="15" cy="13" r="1" fill="currentColor"/><circle cx="17" cy="11" r="1" fill="currentColor"/><path d="M17 5H7a7 7 0 0 0 0 14h10a7 7 0 0 0 0-14z"/></svg></div>
